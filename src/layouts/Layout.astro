---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Jinzi Niu — Portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Portfolio of Jinzi Niu — Designer & Researcher" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-neutral-950 text-neutral-100 font-sans antialiased">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-neutral-950/80 backdrop-blur-md border-b border-neutral-800">
      <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-sm font-medium tracking-widest uppercase text-neutral-400 hover:text-white transition-colors">
          Jinzi Niu
        </a>
        <div class="flex gap-8 text-sm text-neutral-400">
          <a href="/#about" class="hover:text-white transition-colors">About</a>
          <a href="/#projects" class="hover:text-white transition-colors">Projects</a>
          <a href="/cv" class="hover:text-white transition-colors">CV</a>
          <a href="/#contact" class="hover:text-white transition-colors">Contact</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-neutral-800 py-8 text-center text-neutral-600 text-sm">
      © {new Date().getFullYear()} Jinzi Niu
    </footer>
  </body>
</html>

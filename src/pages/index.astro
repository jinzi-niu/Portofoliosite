const skills = [
  { category: "Game Engines", items: ["Unity", "Unreal Engine 5 (Niagara VFX, Blueprints)"] },
  { category: "Programming", items: ["C#", "Git / GitLab", "Visual Studio"] },
  { category: "AI & Automation", items: ["Claude Code", "Claude Agent SDK", "LLM Prompt Engineering"] },
  { category: "3D & Art", items: ["Maya 3D", "Substance 3D Painter", "Photoshop", "Procreate"] },
  { category: "Languages", items: ["Chinese (Native)", "German (C2)", "English (C1)"] },
];
---

<Layout title="Jinzi Niu">
  <div class="max-w-5xl mx-auto px-6 pt-28 pb-16">

    <!-- Header -->
    <div class="flex justify-between items-end flex-wrap gap-4 mb-10 pb-8 border-b border-neutral-800">
      <div class="flex items-center gap-6">
        <img
          src="/images/profile.png"
          alt="Jinzi Niu"
          class="w-48 h-48 rounded-full object-cover shrink-0"
          style="object-position: center 15%;"
        />
        <div>
          <h1 class="text-4xl font-light text-white mb-1">Jinzi Niu</h1>
          <p class="text-neutral-400 text-sm">Game Design Student · Technical Artist · based Berlin</p>
        </div>
      </div>
      <div class="space-y-1 text-right">
        <a href="https://www.linkedin.com/in/jinzi-niu-b94148280" target="_blank" class="text-blue-500 hover:text-blue-300 transition-colors text-lg font-medium block">LinkedIn</a>
        <p class="text-sm text-blue-300/60">jinziniu1310@gmail.com</p>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-10">

      <!-- Left: Skills + Education -->
      <div class="md:col-span-1 space-y-8">

        <div>
          <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-4">Skills</h2>
          <div class="space-y-4">
            {skills.map(skill => (
              <div>
                <p class="text-xs text-neutral-600 mb-1">{skill.category}</p>
                <p class="text-sm text-neutral-300">{skill.items.join(" · ")}</p>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-4 pt-4 border-t border-neutral-800">Education</h2>
          <div class="space-y-4">
            {education.map(edu => (
              <div>
                <p class="text-sm text-neutral-300">{edu.degree}</p>
                <p class="text-xs text-neutral-500">{edu.school}</p>
                <p class="text-xs text-neutral-600">{edu.period}</p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Right: Experience -->
      <div class="md:col-span-2">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-6">Experience</h2>
        <div class="space-y-6">
          {experience.map(job => (
            <div class="flex gap-4">
              <!-- Logo avatar -->
              {job.logo ? (
                <img
                  src={job.logo}
                  alt={job.company}
                  class="shrink-0 w-9 h-9 rounded-lg object-cover mt-0.5 bg-white"
                />
              ) : (
                <div
                  class="shrink-0 w-9 h-9 rounded-lg flex items-center justify-center text-white font-semibold mt-0.5"
                  style={`background-color: ${job.color}; font-size: ${job.initials.length > 2 ? '9px' : '11px'};`}
                >
                  {job.initials}
                </div>
              )}
              <!-- Content -->
              <div class="flex-1">
                <div class="flex justify-between items-start gap-2 flex-wrap">
                  <p class="text-sm text-white font-medium">{job.role}</p>
                  <span class="text-xs text-neutral-600 whitespace-nowrap">{job.period}</span>
                </div>
                <p class="text-xs text-neutral-500 mb-1">{job.company} · {job.location}</p>
                {job.bullets.length > 0 && (
                  <ul class="space-y-0.5 mt-1">
                    {job.bullets.map(b => (
                      <li class="text-xs text-neutral-400 flex gap-2">
                        <span class="text-neutral-700">—</span>{b}
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</Layout>

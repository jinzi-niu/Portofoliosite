---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "Research Assistant & Tutor of LUNA Framework",
    description: "The project of Prof. Thomas Bremer aims to make the game development process more systematic and scientific by creating logical thinking frameworks that make game design concepts more concrete, analyzable, and discussable.",
    role: [
      "Contributed to the initial development of game design concepts such as Ludic Entity, Ludic Activity, and Ludic Actions",
      "Participated in theoretical seminars and discussions",
      "Used Claude Code to analyze feedback from the research process and help implement improvements",
      "Participated in the application of the Luna Framework in game exhibitions and game jams",
    ],
    tags: ["Game Design Research", "GitLab", "Claude", "Notion", "Miro"],
    year: "04.2025 – today",
  },
  {
    title: "F4R — 3D Racing Game",
    description: "A student 3D racing game built with Unreal Engine 5. Main Artist, VFX, character design & modeling, and Sub Ability BP programmer.",
    tags: ["Unreal Engine 5", "VFX", "3D Art", "Blueprints"],
    year: "10.2025 – 03.2026",
    link: "/projects/f4r",
  },
  {
    title: "HARP — 2D Music Puzzle Game",
    description: "A 2D music puzzle game built as a student project. Level design, system design, FMOD audio management, and asset design.",
    tags: ["2D", "Music Puzzle", "FMOD", "Level Design"],
    year: "04.2025 – 09.2025",
    link: "/projects/harp",
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="min-h-screen flex items-center px-6 pt-20">
    <div class="max-w-5xl mx-auto w-full">
      <p class="text-neutral-500 text-sm tracking-widest uppercase mb-6">Designer & Researcher</p>
      <h1 class="text-5xl md:text-7xl font-light leading-tight mb-8 text-white">
        Jinzi Niu
      </h1>
      <p class="text-neutral-400 text-lg md:text-xl max-w-xl leading-relaxed mb-12">
        I design systems and experiences that make complex things feel simple.
        Based in Germany.
      </p>
      <div class="flex gap-4">
        <a href="#projects" class="px-6 py-3 bg-white text-neutral-950 text-sm font-medium rounded-full hover:bg-neutral-200 transition-colors">
          View Projects
        </a>
        <a href="#contact" class="px-6 py-3 border border-neutral-700 text-neutral-300 text-sm font-medium rounded-full hover:border-neutral-400 hover:text-white transition-colors">
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-32 px-6 border-t border-neutral-800">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 items-start">
      <div>
        <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">About</p>
        <h2 class="text-3xl font-light text-white mb-6">A little about me</h2>
      </div>
      <div class="text-neutral-400 leading-relaxed space-y-4">
        <p>
          I'm a designer and researcher currently studying at [Your University].
          My work sits at the intersection of human-centered design, systems thinking,
          and interaction research.
        </p>
        <p>
          I'm interested in how people relate to the spaces, tools, and systems around them —
          and how design can make those relationships more intentional and meaningful.
        </p>
        <div class="pt-4 grid grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-neutral-500 uppercase tracking-wider text-xs mb-2">Skills</p>
            <ul class="space-y-1 text-neutral-300">
              <li>UX / UI Design</li>
              <li>Design Research</li>
              <li>Prototyping</li>
              <li>Systems Thinking</li>
            </ul>
          </div>
          <div>
            <p class="text-neutral-500 uppercase tracking-wider text-xs mb-2">Tools</p>
            <ul class="space-y-1 text-neutral-300">
              <li>Figma</li>
              <li>Miro</li>
              <li>VS Code</li>
              <li>Adobe Suite</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="py-32 px-6 border-t border-neutral-800">
    <div class="max-w-5xl mx-auto">
      <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">Work</p>
      <h2 class="text-3xl font-light text-white mb-16">Selected Projects</h2>

      <div class="space-y-4">
        {projects.map((project, i) => (
          <a href={project.link ?? '#projects'} class={`group p-8 border border-neutral-800 rounded-2xl hover:border-neutral-600 transition-all hover:bg-neutral-900/50 block ${project.link ? 'cursor-pointer' : 'cursor-default'}`}>
            <div class="flex justify-between items-start mb-4">
              <div class="flex items-center gap-4">
                <span class="text-neutral-600 text-sm">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="text-xl font-medium text-white group-hover:text-neutral-100">{project.title}</h3>
              </div>
              <span class="text-neutral-600 text-sm">{project.year}</span>
            </div>
            <p class="text-neutral-400 ml-8 mb-4 leading-relaxed">{project.description}</p>
            {project.role && (
              <ul class="ml-8 mb-4 space-y-1">
                {project.role.map(item => (
                  <li class="text-neutral-500 text-sm flex gap-2">
                    <span class="text-neutral-700">—</span> {item}
                  </li>
                ))}
              </ul>
            )}
            <div class="ml-8 flex gap-2 flex-wrap">
              {project.tags && project.tags.map(tag => (
                <span class="px-3 py-1 bg-neutral-800 text-neutral-400 text-xs rounded-full">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-32 px-6 border-t border-neutral-800">
    <div class="max-w-5xl mx-auto text-center">
      <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">Contact</p>
      <h2 class="text-4xl md:text-5xl font-light text-white mb-6">Let's work together</h2>
      <p class="text-neutral-400 mb-12 max-w-md mx-auto">
        Open to collaborations, internships, and interesting conversations.
      </p>
      <div class="flex justify-center gap-6 flex-wrap">
        <a href="mailto:your@email.com" class="px-8 py-4 bg-white text-neutral-950 text-sm font-medium rounded-full hover:bg-neutral-200 transition-colors">
          your@email.com
        </a>
        <a href="https://linkedin.com/in/yourprofile" target="_blank" class="px-8 py-4 border border-neutral-700 text-neutral-300 text-sm font-medium rounded-full hover:border-neutral-400 hover:text-white transition-colors">
          LinkedIn
        </a>
      </div>
    </div>
  </section>
</Layout>

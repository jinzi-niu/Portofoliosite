const education = [
  {
    degree: "B.Sc. Game Design",
    school: "HTW Berlin",
    period: "Sept 2024 – Present",
  },
  {
    degree: "M.A. German Literature — Aesthetics & Philosophy",
    school: "Humboldt-Universität zu Berlin",

---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "F4R",
    subtitle: "3D Racing Game",
    description: "A student 3D racing game built with Unreal Engine 5. Technical Artist, VFX, character design & modeling, sound design, and team project management.",
    tags: ["Unreal Engine 5", "UE5 Blueprint", "Maya 3D", "Blender", "Procreate"],
    year: "10.2025 – 03.2026",
    link: "/projects/f4r",
    image: "/images/f4r-title.png",
  },
  {
    title: "HARP",
    subtitle: "2D Music Puzzle Game",
    description: "A 2D music puzzle game built as a student project. Level design, system design, FMOD audio management, and asset design.",
    tags: ["2D", "Music Puzzle", "FMOD", "Level Design"],
    year: "04.2025 – 09.2025",
    link: "/projects/harp",
    image: "/images/harp-title.png",
  },
  {
    title: "RoseGame — The Idol",
    subtitle: "Personal 3D Project",
    description: "A 3D idol created to reflect the worldview of RoseGame — a personal story. A centaur entwined with rose vines: the centaur represents social rules, the roses symbolise desire and its relentless spread.",
    tags: ["3D Art", "Personal Project", "World Building"],
    year: "2025",
    link: "/projects/personal-3d",
    image: "/images/personal-3d/title.png",
  },
  {
    title: "Impro Pantho",
    subtitle: "Outdoor Game",
    description: "An outdoor improvisation pantomime game combining physical theatre and non-lingual communication. Players act out secret actions and pass them along a chain — the last player must guess the original.",
    tags: ["Outdoor Game", "Improvisation", "Physical Theatre", "Teamwork"],
    year: "2025",
    link: "/projects/outdoor-game",
    image: "/images/outdoor-cover.jpg",
  },
];
---

<Layout title="Game Projects — Jinzi Niu">
  <div class="max-w-5xl mx-auto px-6 pt-28 pb-16">

    <div class="mb-12 flex justify-between items-center flex-wrap gap-6">
      <div>
        <h1 class="text-4xl font-light mb-2">
          <span style="color: #FE6237;">Game </span><span style="color: #FFB62E;">Projects </span><span style="color: #7CC3FF;">of </span><span style="color: #4164FF;">Jinzi </span><span style="color: #FE6237;">Niu</span>
        </h1>
        <p class="text-neutral-500 text-sm">Hi, I love games — and making games even more!</p>
      </div>
      <div class="w-28 h-28 rounded-full border-2 border-neutral-600 overflow-hidden bg-neutral-800 shrink-0">
        <img src="/images/profile.png" alt="Jinzi Niu" class="w-full h-full object-cover" style="object-position: center 15%;" />
      </div>
    </div>

    <div class="space-y-4">
      {projects.map((project, i) => (
        <a
          href={project.link}
          class="group relative overflow-hidden flex gap-8 border border-neutral-800 rounded-2xl hover:border-neutral-600 transition-all block"
        >
          <!-- Background image -->
          <div class="absolute inset-0">
            <img src={project.image} alt="" class="w-full h-full object-cover opacity-100 transition-opacity" />
            <div class="absolute inset-0 bg-gradient-to-r from-neutral-950/60 via-neutral-950/30 to-neutral-950/10"></div>
          </div>

          <!-- Content -->
          <div class="relative z-10 flex gap-8 p-8 w-full">
            <span class="text-neutral-600 text-3xl font-light shrink-0">0{i + 1}</span>
            <div class="flex-1">
              <div class="flex justify-between items-start flex-wrap gap-2 mb-2">
                <div>
                  <h2 class="text-xl font-medium text-white">{project.title}</h2>
                  <p class="text-neutral-400 text-sm">{project.subtitle}</p>
                </div>
                <span class="text-neutral-500 text-sm">{project.year}</span>
              </div>
              <p class="text-neutral-300 text-sm leading-relaxed mb-4">{project.description}</p>
              <div class="flex gap-2 flex-wrap">
                {project.tags.map(tag => (
                  <span class="px-3 py-1 bg-white/10 text-neutral-300 text-xs rounded-full">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</Layout>

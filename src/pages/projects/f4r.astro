---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="F4R — Jinzi Niu">
  <!-- Background image at 50% opacity -->
  <div class="fixed inset-0 -z-10">
    <img src="/images/f4r-bg.png" alt="" class="w-full h-full object-cover opacity-50" />
  </div>

  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">

    <!-- Back -->
    <a href="/#projects" class="text-sm text-neutral-500 hover:text-white transition-colors mb-12 inline-block">
      ← Back to Projects
    </a>

    <!-- Header -->
    <div class="mb-16">
      <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">3D Racing Game · Student Project</p>
      <h1 class="text-5xl md:text-6xl font-light text-white mb-6">F4R</h1>
      <div class="flex gap-4 flex-wrap items-center">
        <span class="text-neutral-500 text-sm">10.2025 – 03.2026</span>
        <span class="text-neutral-700">·</span>
        <a
          href="https://dojisale.itch.io/f4r"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2 bg-white text-neutral-950 text-sm font-medium rounded-full hover:bg-neutral-200 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zm3.5 7.5a.5.5 0 0 1 0 1H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5z"/>
          </svg>
          Play on itch.io
        </a>
      </div>
    </div>

    <!-- Video -->
    <div class="mb-16 rounded-2xl overflow-hidden aspect-video w-full">
      <iframe
        class="w-full h-full"
        src="https://www.youtube.com/embed/9ZRVLHgvmrk"
        title="F4R — Official Trailer"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    <!-- Divider -->
    <div class="border-t border-neutral-800 mb-16"></div>

    <!-- Content -->
    <div class="grid md:grid-cols-3 gap-12">

      <!-- My Role -->
      <div class="md:col-span-1">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-6">My Role</h2>
        <p class="text-xs text-neutral-500 uppercase tracking-wider mb-3">Technical Artist</p>
        <ul class="space-y-3 text-sm text-neutral-300 mb-6">
          <li class="flex gap-2"><span class="text-neutral-700">—</span> Skybox, Skybox Cubemaps & VFX</li>
          <li class="flex gap-2"><span class="text-neutral-700">—</span> Environmental & Character VFX</li>
          <li class="flex gap-2"><span class="text-neutral-700">—</span> Character Design, Modeling & Materials</li>
          <li class="flex gap-2"><span class="text-neutral-700">—</span> Environment Materials</li>
          <li class="flex gap-2"><span class="text-neutral-700">—</span> Game Color Palette</li>
          <li class="flex gap-2"><span class="text-neutral-700">—</span> <span>Sub Ability BP Programmer <span class="text-neutral-600 text-xs">(cancelled in final)</span></span></li>
          <li class="flex gap-2"><span class="text-neutral-700">—</span> Team Project Management</li>
        </ul>
        <p class="text-xs text-neutral-500 uppercase tracking-wider mb-3">Sound Design</p>
        <ul class="space-y-3 text-sm text-neutral-300">
          <li class="flex gap-2"><span class="text-neutral-700">—</span> Background Music</li>
        </ul>

        <div class="mt-10">
          <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-4">Tags</h2>
          <div class="flex gap-2 flex-wrap">
            <span class="px-3 py-1 bg-neutral-800 text-neutral-400 text-xs rounded-full">Unreal Engine 5</span>
            <span class="px-3 py-1 bg-neutral-800 text-neutral-400 text-xs rounded-full">UE5 Blueprint</span>
            <span class="px-3 py-1 bg-neutral-800 text-neutral-400 text-xs rounded-full">Maya 3D</span>
            <span class="px-3 py-1 bg-neutral-800 text-neutral-400 text-xs rounded-full">Blender</span>
            <span class="px-3 py-1 bg-neutral-800 text-neutral-400 text-xs rounded-full">Procreate</span>
          </div>
        </div>
      </div>

      <!-- Description -->
      <div class="md:col-span-2">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-6">About the Project</h2>
        <div class="text-neutral-400 leading-relaxed space-y-4">
          <p>
            F4R is a 3D racing game developed as a student project at HTW Berlin.
            Add your description here — what is the game about, what was the concept, what makes it special?
          </p>
          <p>
            You can describe the gameplay, the visual style, the team, or any challenges you solved.
          </p>
        </div>

        <!-- Play CTA -->
        <div class="mt-12 p-6 border border-neutral-800 rounded-2xl flex items-center justify-between gap-4 flex-wrap">
          <div>
            <p class="text-white font-medium mb-1">Play F4R</p>
            <p class="text-neutral-500 text-sm">Available on itch.io</p>
          </div>
          <a
            href="https://dojisale.itch.io/f4r"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 bg-white text-neutral-950 text-sm font-medium rounded-full hover:bg-neutral-200 transition-colors"
          >
            dojisale.itch.io/f4r →
          </a>
        </div>
      </div>

    </div>

  </div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Personal 3D Project — Jinzi Niu">
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">

    <!-- Back -->
    <a href="/" class="text-sm text-neutral-500 hover:text-white transition-colors mb-12 inline-block">
      ← Back to Game Projects
    </a>

    <!-- Header -->
    <div class="mb-16">
      <p class="text-neutral-500 text-sm tracking-widest uppercase mb-4">Personal 3D Project</p>
      <h1 class="text-5xl md:text-6xl font-light text-white mb-6">RoseGame — The Idol</h1>
      <div class="flex gap-2 flex-wrap">
        <span class="px-3 py-1 bg-neutral-800 text-neutral-400 text-xs rounded-full">3D Art</span>
        <span class="px-3 py-1 bg-neutral-800 text-neutral-400 text-xs rounded-full">Personal Project</span>
        <span class="px-3 py-1 bg-neutral-800 text-neutral-400 text-xs rounded-full">World Building</span>
      </div>
    </div>

    <!-- Video -->
    <div class="mb-16 rounded-2xl overflow-hidden aspect-video w-full">
      <iframe
        class="w-full h-full"
        src="https://www.youtube.com/embed/lKviJ3wp_7A"
        title="RoseGame — The Idol"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    <!-- Divider -->
    <div class="border-t border-neutral-800 mb-16"></div>

    <!-- About -->
    <div class="max-w-2xl">
      <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-6">About the Project</h2>
      <div class="text-neutral-300 leading-relaxed space-y-4">
        <p>
          This is an idol I created to reflect the worldview of <span class="italic text-white">RoseGame</span> —
          a story I wrote out of personal interest.
        </p>
        <p>
          The idol depicts a centaur entwined with rose vines. The centaur represents social rules and order,
          while the tangled, sprawling roses symbolise desire and its relentless spread.
        </p>
      </div>
    </div>

    <!-- Centaur Concept Design -->
    <div class="mt-24">
      <div class="border-t border-neutral-800 pt-12 mb-10">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500">Centaur Concept Design</h2>
      </div>
      <div class="flex flex-col gap-12">
        <img src="/images/personal-3d/concept2.png" alt="Concept 2" class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/draw1.png"    alt="Draw 1"    class="w-full object-contain rounded-2xl" />
      </div>
    </div>

    <!-- Details in MAYA -->
    <div class="mt-24">
      <div class="border-t border-neutral-800 pt-12 mb-10">
        <h2 class="text-xs uppercase tracking-widest text-neutral-500">Details in MAYA</h2>
      </div>
      <div class="flex flex-col gap-12">
        <img src="/images/personal-3d/maya1.png"  alt="Maya 1"  class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/maya2.png"  alt="Maya 2"  class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/maya3.png"  alt="Maya 3"  class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/maya4.png"  alt="Maya 4"  class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/maya5.png"  alt="Maya 5"  class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/maya6.png"  alt="Maya 6"  class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/maya7.png"  alt="Maya 7"  class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/maya9.png"  alt="Maya 9"  class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/maya10.png" alt="Maya 10" class="w-full object-contain rounded-2xl" />
        <img src="/images/personal-3d/maya11.png" alt="Maya 11" class="w-full object-contain rounded-2xl" />
      </div>
    </div>

  </div>
</Layout>

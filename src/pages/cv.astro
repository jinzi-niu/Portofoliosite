---

<Layout title="CV — Jinzi Niu">
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24">

    <!-- Header -->
    <div class="mb-16 flex justify-between items-start flex-wrap gap-6">
      <div>
        <p class="text-neutral-500 text-sm tracking-widest uppercase mb-3">Curriculum Vitae</p>
        <h1 class="text-5xl font-light text-white mb-2">Jinzi Niu</h1>
        <p class="text-neutral-400">Game Designer · Researcher · Artist</p>
      </div>
      <a
        href="/"
        class="text-sm text-neutral-500 hover:text-white transition-colors mt-2"
      >
        ← Back to Portfolio
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-12">

      <!-- Left column: Skills -->
      <div class="md:col-span-1 space-y-10">

        <div>
          <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-6 pb-2 border-b border-neutral-800">
            Technical Skills
          </h2>
          <div class="space-y-6">
            {skills.map(skill => (
              <div>
                <p class="text-xs text-neutral-500 mb-2">{skill.category}</p>
                <ul class="space-y-1">
                  {skill.items.map(item => (
                    <li class="text-sm text-neutral-300">{item}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Right column: Experience + Education -->
      <div class="md:col-span-2 space-y-16">

        <!-- Experience -->
        <div>
          <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-8 pb-2 border-b border-neutral-800">
            Experience
          </h2>
          <div class="space-y-8">
            {experience.map(job => (
              <div>
                <div class="flex justify-between items-start flex-wrap gap-1 mb-1">
                  <h3 class="text-white font-medium text-sm">{job.role}</h3>
                  <span class="text-neutral-600 text-xs whitespace-nowrap">{job.period}</span>
                </div>
                <p class="text-neutral-500 text-xs mb-3">{job.company} · {job.location}</p>
                <ul class="space-y-1">
                  {job.bullets.map(b => (
                    <li class="text-neutral-400 text-sm flex gap-2">
                      <span class="text-neutral-700 mt-1">—</span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

        <!-- Education -->
        <div>
          <h2 class="text-xs uppercase tracking-widest text-neutral-500 mb-8 pb-2 border-b border-neutral-800">
            Education
          </h2>
          <div class="space-y-8">
            {education.map(edu => (
              <div>
                <div class="flex justify-between items-start flex-wrap gap-1 mb-1">
                  <h3 class="text-white font-medium text-sm">{edu.degree}</h3>
                  <span class="text-neutral-600 text-xs whitespace-nowrap">{edu.period}</span>
                </div>
                <p class="text-neutral-500 text-xs mb-3">{edu.school} · {edu.location}</p>
                <ul class="space-y-1">
                  {edu.bullets.map(b => (
                    <li class="text-neutral-400 text-sm flex gap-2">
                      <span class="text-neutral-700 mt-1">—</span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>
